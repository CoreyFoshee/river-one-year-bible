# Copy to .env for local Netlify dev (netlify dev loads .env automatically).
# In Netlify: Site settings → Environment variables.

# Required: API.Bible key from https://scripture.api.bible/
API_BIBLE_KEY=

# Optional: override Bible ID. Default in code = NIV 2011 (verify with GET /v1/bibles?abbreviation=NIV).
BIBLE_ID=78a9f6124f344018-01

# Optional: "Today" and prev/next use this IANA timezone (Marion / The River area).
VITE_PUBLIC_TIMEZONE=America/Indiana/Indianapolis
